# OpenCode Config — Template Gitignore

# Personal identity (never share these)
USER.md

# Memory files — exclude all except templates + sanitized index
memory/archive/
memory/mailboxes/
memory/checkpoint.yaml
memory/schedule.yaml
memory/*.md
!memory/MEMORY.md
!memory/*.template.md

# Personal project deploy configs
scripts/workflows/*.yml

# Personal educational documents
scripts/GUIA-*.docx
scripts/create_*.py
scripts/extract_*.py
scripts/verify_*.py
scripts/transfer_*.py
scripts/check_*.py
scripts/analyze_*.py
scripts/debug_*.py
scripts/scrape_*.py
scripts/try_*.py
scripts/fill_*.py
scripts/copy_*.py
scripts/compare_*.py
scripts/generate_*.py
scripts/get_*.py
scripts/list_*.py
scripts/unpack_*.py
scripts/test_parse*.py

# Old ETL archive scripts
scripts/_archive_etl_old_versions/
scripts/archive/

# Personal project skill directories
skills/.archive/pria-material-generator/
skills/.archive/buddy-sings/

# Planning and project docs (internal only)
CI_CD_READY.md
DEPLOYMENT_QUICK_START.txt
DEV_AGENCY_*.md
FINAL_IMPROVEMENT_POA.md
HARNESS_IMPROVEMENT_POA.md
HERMES_INTEGRATION_README.md
HOOK_*.md
HOOK_*.txt
PROVIDER_FAILOVER_SETUP.md
SYSTEM_OPTIMIZATION_POA.md
GRAPH_MIGRATION_SOP.md
smoke_test/

# Auto-generated indexes
SKILLS_INDEX.json
audit_inventory.json
audits/

# Binary and large files
skills/LEGACY_VAULT.zip
skills/.archive/frontend-dev/canvas-fonts/*.ttf
*.zip

# Backup files
*.bak
_*_backup_*/**
_*_backup_*/

# Tool output (runtime artifacts)
tool-output/
_source/
_source_test/

# Extracted MCP tools
playwright-browsers/
ms-playwright/

# Secrets (never commit)
*.env
.env.*
**/*.env

# Node modules
node_modules/

# Python cache
__pycache__/
*.pyc
*.pyo

# OS files
Thumbs.db
.DS_Store

memory/reviews/memory/interventions.json